  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#908070",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template"
      ],
      "settings": {
        "foreground": "#6A4820"
      }
    },
    {
      "name": "String Template Expression",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#406030"
      }
    },
    {
      "name": "String Escape",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#886020"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp",
        "keyword.operator.quantifier.regexp"
      ],
      "settings": {
        "foreground": "#886020"
      }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#7A6020"
      }
    },
    {
      "name": "Language Constant",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.none"
      ],
      "settings": {
        "foreground": "#7A5020"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.return",
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "#406030",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.new",
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic"
      ],
      "settings": {
        "foreground": "#706860",
        "fontStyle": ""
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.type",
        "storage.type.js",
        "storage.type.ts",
        "storage.type.function",
        "storage.type.class",
        "storage.type.enum",
        "storage.type.interface"
      ],
      "settings": {
        "foreground": "#406030",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage Modifier",
      "scope": [
        "storage.modifier",
        "storage.modifier.async",
        "storage.modifier.static",
        "storage.modifier.readonly",
        "storage.modifier.private",
        "storage.modifier.public",
        "storage.modifier.protected"
      ],
      "settings": {
        "foreground": "#406030",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "Type / Class",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.module",
        "entity.name.enum",
        "entity.name.interface",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#507840"
      }
    },
    {
      "name": "Function Declaration",
      "scope": [
        "entity.name.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": {
        "foreground": "#302C26",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function Call",
      "scope": ["meta.function-call entity.name.function", "support.function"],
      "settings": {
        "foreground": "#302C26"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other", "variable.other.readwrite"],
      "settings": {
        "foreground": "#302C26"
      }
    },
    {
      "name": "Language Variable",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#406030",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#504030",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Object Property",
      "scope": ["variable.other.property", "meta.object-literal.key"],
      "settings": {
        "foreground": "#507840"
      }
    },
    {
      "name": "HTML Tag",
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#406030"
      }
    },
    {
      "name": "HTML Attribute Name",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#507840"
      }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#908880"
      }
    },
    {
      "name": "Punctuation Tag",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#587848"
      }
    },
    {
      "name": "CSS Selector",
      "scope": [
        "meta.selector",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-class.css"
      ],
      "settings": {
        "foreground": "#406030"
      }
    },
    {
      "name": "CSS Property",
      "scope": ["support.type.property-name.css", "support.type.property-name"],
      "settings": {
        "foreground": "#504840"
      }
    },
    {
      "name": "CSS Value",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#6A4820"
      }
    },
    {
      "name": "CSS Unit / Number",
      "scope": ["keyword.other.unit", "constant.numeric.css"],
      "settings": {
        "foreground": "#7A6020"
      }
    },
    {
      "name": "JSON Key",
      "scope": [
        "support.type.property-name.json",
        "meta.structure.dictionary.json meta.structure.dictionary.key.json string"
      ],
      "settings": {
        "foreground": "#507840"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#406030",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#1C1810",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#302C26",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw", "markup.raw.block"],
      "settings": {
        "foreground": "#6A4820"
      }
    },
    {
      "name": "Markdown Link",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#406030"
      }
    },
    {
      "name": "Decorator / Annotation",
      "scope": ["meta.decorator", "entity.name.function.decorator"],
      "settings": {
        "foreground": "#7A5020",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": {
        "foreground": "#8A3020",
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "comment": { "foreground": "#908070", "italic": true },
    "keyword": { "foreground": "#406030", "bold": true },
    "string": { "foreground": "#6A4820" },
    "number": { "foreground": "#7A6020" },
    "type": { "foreground": "#507840" },
    "class": { "foreground": "#507840" },
    "interface": { "foreground": "#507840" },
    "enum": { "foreground": "#507840" },
    "enumMember": { "foreground": "#7A5020" },
    "function": { "foreground": "#302C26", "italic": true },
    "method": { "foreground": "#302C26", "italic": true },
    "variable": { "foreground": "#302C26" },
    "variable.readonly": { "foreground": "#7A5020" },
    "parameter": { "foreground": "#504030", "italic": true },
    "property": { "foreground": "#507840" },
    "property.readonly": { "foreground": "#7A5020" },
    "namespace": { "foreground": "#507840" },
    "decorator": { "foreground": "#7A5020", "italic": true },
    "operator": { "foreground": "#706860" },
    "punctuation": { "foreground": "#908880" },
    "selfKeyword": { "foreground": "#406030", "italic": true }
  }
}
