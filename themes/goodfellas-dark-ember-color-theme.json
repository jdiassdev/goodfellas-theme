  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#524E48",
        "fontStyle": "italic"
      }
    },

    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template"
      ],
      "settings": {
        "foreground": "#5AA870"
      }
    },
    {
      "name": "String Template Expression",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#C89040"
      }
    },
    {
      "name": "String Escape",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#E0C040"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp",
        "keyword.operator.quantifier.regexp",
        "punctuation.definition.group.regexp"
      ],
      "settings": {
        "foreground": "#E0C040"
      }
    },

    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#C8782A"
      }
    },

    {
      "name": "Language Constant — true / false / null / undefined",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.none"
      ],
      "settings": {
        "foreground": "#C06868"
      }
    },
    {
      "name": "Constant Other",
      "scope": ["constant.other"],
      "settings": {
        "foreground": "#B85858"
      }
    },

    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.return",
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "#C89040",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.instanceof",
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic"
      ],
      "settings": {
        "foreground": "#706858",
        "fontStyle": ""
      }
    },

    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.type",
        "storage.type.js",
        "storage.type.ts",
        "storage.type.function",
        "storage.type.class",
        "storage.type.enum",
        "storage.type.interface",
        "storage.type.type"
      ],
      "settings": {
        "foreground": "#C89040",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage Modifier",
      "scope": [
        "storage.modifier",
        "storage.modifier.async",
        "storage.modifier.static",
        "storage.modifier.readonly",
        "storage.modifier.private",
        "storage.modifier.public",
        "storage.modifier.protected",
        "storage.modifier.abstract"
      ],
      "settings": {
        "foreground": "#C89040",
        "fontStyle": "italic bold"
      }
    },

    {
      "name": "Type / Class / Interface / Enum",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.module",
        "entity.name.enum",
        "entity.name.interface",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#5A9BD4"
      }
    },

    {
      "name": "Function Declaration",
      "scope": [
        "entity.name.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": {
        "foreground": "#9B6FCC",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function Call",
      "scope": [
        "meta.function-call entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#B898E0"
      }
    },

    {
      "name": "Variable",
      "scope": ["variable", "variable.other", "variable.other.readwrite"],
      "settings": {
        "foreground": "#D0C9B8"
      }
    },
    {
      "name": "Language Variable — this / self / super",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#C89040",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#B0A890",
        "fontStyle": "italic"
      }
    },

    {
      "name": "Object Property / Key",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#3AABA0"
      }
    },

    {
      "name": "HTML Tag",
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#C89040"
      }
    },
    {
      "name": "HTML Attribute Name",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#3AABA0"
      }
    },

    {
      "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#585450"
      }
    },
    {
      "name": "Punctuation Tag",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#907030"
      }
    },
    {
      "name": "Punctuation Accessor",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.dot-access",
        "punctuation.separator.period"
      ],
      "settings": {
        "foreground": "#786858"
      }
    },

    {
      "name": "CSS Selector",
      "scope": [
        "meta.selector",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#5A9BD4"
      }
    },
    {
      "name": "CSS Property",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#3AABA0"
      }
    },
    {
      "name": "CSS Value",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#5AA870"
      }
    },
    {
      "name": "CSS Unit / Color",
      "scope": [
        "keyword.other.unit",
        "constant.numeric.css",
        "constant.other.color.rgb-value.css",
        "support.constant.color"
      ],
      "settings": {
        "foreground": "#C8782A"
      }
    },

    {
      "name": "JSON Key",
      "scope": [
        "support.type.property-name.json",
        "meta.structure.dictionary.json meta.structure.dictionary.key.json string"
      ],
      "settings": {
        "foreground": "#5A9BD4"
      }
    },

    {
      "name": "Markdown Heading",
      "scope": ["markup.heading", "entity.name.section", "punctuation.definition.heading"],
      "settings": {
        "foreground": "#9B6FCC",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#E8E0D0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#D0C9B8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw", "markup.raw.block", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#C89040"
      }
    },
    {
      "name": "Markdown Link",
      "scope": ["markup.underline.link", "string.other.link.title.markdown"],
      "settings": {
        "foreground": "#5A9BD4"
      }
    },
    {
      "name": "Markdown List",
      "scope": ["markup.list", "punctuation.definition.list.begin"],
      "settings": {
        "foreground": "#3AABA0"
      }
    },

    {
      "name": "Decorator / Annotation",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#A86820",
        "fontStyle": "italic"
      }
    },

    {
      "name": "Rust Lifetime",
      "scope": ["storage.modifier.lifetime.rust", "entity.name.lifetime.rust"],
      "settings": {
        "foreground": "#C06868",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust / Python Macro / Builtin",
      "scope": [
        "support.macro.rust",
        "entity.name.function.macro.rust",
        "support.function.builtin.python"
      ],
      "settings": {
        "foreground": "#A86820",
        "fontStyle": "italic"
      }
    },

    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": {
        "foreground": "#D45858",
        "fontStyle": "strikethrough"
      }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#686460",
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "comment":            { "foreground": "#524E48", "italic": true },
    "keyword":            { "foreground": "#C89040", "bold": true },
    "string":             { "foreground": "#5AA870" },
    "number":             { "foreground": "#C8782A" },
    "type":               { "foreground": "#5A9BD4" },
    "class":              { "foreground": "#5A9BD4" },
    "interface":          { "foreground": "#5A9BD4" },
    "enum":               { "foreground": "#5A9BD4" },
    "enumMember":         { "foreground": "#C06868" },
    "function":           { "foreground": "#9B6FCC", "italic": true },
    "method":             { "foreground": "#9B6FCC", "italic": true },
    "variable":           { "foreground": "#D0C9B8" },
    "variable.readonly":  { "foreground": "#C06868" },
